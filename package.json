{
  "name": "fx-learning-rpg-site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/vercel-copy-base-output.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "note:generate": "node scripts/note/generate-note-posts.mjs",
    "note:post": "node scripts/note/post-note-draft.mjs",
    "note:publish": "node scripts/note/publish-note-draft.mjs",
    "note:generate:public": "node scripts/note/generate-note-posts.mjs --count=1 --type=public",
    "note:generate:member": "node scripts/note/generate-note-posts.mjs --count=1 --type=member"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.5",
    "@pagefind/default-ui": "^1.5.2",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.3.5",
    "pagefind": "^1.5.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
