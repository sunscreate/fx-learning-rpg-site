---
const {
  level = 1,
  exp = 0,
  streak = 0,
  learnedArticles = 0,
  totalArticles = 0,
  nextQuest = "？？？",
} = Astro.props;

const progress =
  totalArticles > 0
    ? Math.floor(
        (learnedArticles /
          totalArticles) *
          100
      )
    : 0;

function getTitle(level) {
  if (level >= 20) {
    return "Guild Master";
  }

  if (level >= 15) {
    return "Market Knight";
  }

  if (level >= 10) {
    return "Elite Trader";
  }

  if (level >= 5) {
    return "Adventurer";
  }

  return "Novice";
}

const title =
  getTitle(level);
---

<div class="dashboard-card">
  <div class="dashboard-header">
    Guild Status
  </div>

  <div class="dashboard-grid">
    <div class="dashboard-item">
      <span>LEVEL</span>
      <strong>
        LV {level}
      </strong>
    </div>

    <div class="dashboard-item">
      <span>TITLE</span>
      <strong>{title}</strong>
    </div>

    <div class="dashboard-item">
      <span>TOTAL EXP</span>
      <strong>{exp}</strong>
    </div>

    <div class="dashboard-item">
      <span>STREAK</span>
      <strong>
        🔥 {streak} DAYS
      </strong>
    </div>
  </div>

  <div class="learning-progress">
    <div class="progress-top">
      <span>
        Learned Articles
      </span>

      <span>
        {learnedArticles}
        /
        {totalArticles}
      </span>
    </div>

    <div class="progress-bar">
      <div
        class="progress-fill"
        style={`width:${progress}%`}
      ></div>
    </div>

    <div class="progress-text">
      {progress}%
    </div>
  </div>

  <div class="next-quest">
    <span>NEXT QUEST</span>

    <strong>
      → {nextQuest}
    </strong>
  </div>
</div>

<style>
  .dashboard-card {
    background: #111827;
    border: 1px solid #1f2937;
    border-radius: 20px;
    padding: 32px;
    margin: 40px 0;
  }

  .dashboard-header {
    font-size: 28px;
    font-weight: bold;
    margin-bottom: 32px;
    color: #f9fafb;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns:
      repeat(auto-fit, minmax(180px, 1fr));
    gap: 18px;
    margin-bottom: 36px;
  }

  .dashboard-item {
    background: #0f172a;
    border-radius: 14px;
    padding: 20px;
    border: 1px solid #1f2937;
  }

  .dashboard-item span {
    display: block;
    margin-bottom: 10px;
    font-size: 12px;
    color: #9ca3af;
  }

  .dashboard-item strong {
    color: #f9fafb;
    font-size: 24px;
  }

  .learning-progress {
    margin-bottom: 36px;
  }

  .progress-top {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
    color: #f3f4f6;
  }

  .progress-bar {
    width: 100%;
    height: 18px;
    background: #1f2937;
    border-radius: 999px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background:
      linear-gradient(
        90deg,
        #00ff99,
        #00ccff
      );
  }

  .progress-text {
    margin-top: 10px;
    color: #f9fafb;
    font-weight: bold;
  }

  .next-quest {
    background: #0f172a;
    border: 1px solid #1f2937;
    border-radius: 16px;
    padding: 20px;
  }

  .next-quest span {
    display: block;
    margin-bottom: 12px;
    color: #9ca3af;
    font-size: 12px;
  }

  .next-quest strong {
    color: #00ff99;
    font-size: 22px;
  }
</style>
