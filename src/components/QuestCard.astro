---
const {
  article,
  collection,
} = Astro.props;

const slug =
  article.slug ||
  article.id.replace(".md", "");

const href =
  `/fx-learning-rpg-site/category/${collection}/${slug}/`;
---

<a
  href={href}
  class="quest-card"
  data-slug={slug}
>

  <div class="quest-top">

    <span class="quest-level">
      LEVEL {article.data.level}
    </span>

    <span
      class="quest-status"
      id={`status-${slug}`}
    >
      未クリア
    </span>

  </div>

  <h3>
    {article.data.title}
  </h3>

  <p>
    {article.data.description}
  </p>

</a>

<script define:vars={{ slug }}>
const SAVE_KEY =
  "fx-quest-guild-save";

const saveData =
  JSON.parse(
    localStorage.getItem(SAVE_KEY) || "{}"
  );

const learnedArticles =
  saveData.learnedArticles || [];

const completedQuests =
  saveData.completedQuests || [];

const legacyLearned =
  JSON.parse(
    localStorage.getItem("fxQuestLearned") || "[]"
  );

const isClear =
  learnedArticles.includes(slug) ||
  completedQuests.includes(slug) ||
  legacyLearned.includes(slug);

if (isClear) {
  const el =
    document.getElementById(
      `status-${slug}`
    );

  if (el) {
    el.textContent = "CLEAR";
    el.classList.add("clear");
  }
}
</script>

<style>

.quest-card {
  display: block;
  padding: 24px;
  border-radius: 20px;
  background: #111827;
  border: 1px solid #1f2937;
  transition: 0.25s;
  text-decoration: none;
}

.quest-card:hover {
  transform: translateY(-4px);
  border-color: #2563eb;
}

.quest-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.quest-level {
  color: #60a5fa;
  font-size: 13px;
  font-weight: bold;
}

.quest-status {
  font-size: 12px;
  padding: 4px 10px;
  border-radius: 999px;
  background: #3f3f46;
  color: #d4d4d8;
}

.quest-status.clear {
  background: #14532d;
  color: #86efac;
}

.quest-card h3 {
  color: white;
  margin-bottom: 12px;
}

.quest-card p {
  color: #9ca3af;
  line-height: 1.7;
}

</style>
