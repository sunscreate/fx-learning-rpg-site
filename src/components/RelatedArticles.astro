---
import { getCollection } from "astro:content";
import { mainQuestList } from "../data/mainQuestList.js";

const {
  currentSlug,
  currentArticleLevel,
} = Astro.props;

const collections = [
  "basic",
  "chart",
  "entry",
  "technical",
  "risk",
  "mental",
  "market",
  "fundamental",
  "analysis",
  "style",
  "advanced",
  "operation",
  "ea",
  "glossary",
];

let allPosts = [];

for (const collection of collections) {
  const posts =
    await getCollection(collection);

  allPosts.push(
    ...posts.map((post) => ({
      ...post,
      collection,
      fixedSlug:
        post.slug ||
        post.id.replace(/\\.md$/, ""),
    }))
  );
}

const mainSlugs =
  mainQuestList[currentArticleLevel] || [];

const relatedPosts = allPosts
  .filter((post) => {
    return (
      post.fixedSlug !== currentSlug &&
      post.data.level === currentArticleLevel &&
      !mainSlugs.includes(post.fixedSlug)
    );
  })
  .slice(0, 6);
---

{
  relatedPosts.length > 0 && (
    <section class="related-section">
      <p class="side-label">
        SIDE QUEST
      </p>

      <h2>
        📘 補足QUEST
      </h2>

      <p class="side-description">
        メインQUESTの理解を深めるための補足記事です。
      </p>

      <div class="related-grid">
        {relatedPosts.map((post) => (
          <a
            href={`/fx-learning-rpg-site/category/${post.collection}/${post.fixedSlug}/`}
            class="related-card"
          >
            <div class="related-top">
              <span>
                LEVEL {post.data.level}
              </span>

              <strong>
                +20 EXP
              </strong>
            </div>

            <h3>{post.data.title}</h3>

            <p>
              {post.data.description}
            </p>

            <div class="side-button">
              補足QUESTへ進む →
            </div>
          </a>
        ))}
      </div>
    </section>
  )
}

<style>
  .related-section {
    margin-top: 64px;
    padding: 32px;
    border-radius: 24px;
    background: #0f172a;
    border: 1px solid #1f2937;
  }

  .side-label {
    color: #38bdf8;
    font-weight: 900;
    letter-spacing: 0.08em;
    font-size: 13px;
    margin-bottom: 8px;
  }

  .related-section h2 {
    margin-bottom: 10px;
    font-size: 28px;
    color: #f9fafb;
  }

  .side-description {
    color: #9ca3af;
    margin-bottom: 24px;
  }

  .related-grid {
    display: grid;
    gap: 20px;
  }

  .related-card {
    display: block;
    background: #111827;
    border: 1px solid #1f2937;
    border-radius: 18px;
    padding: 24px;
    transition: 0.25s;
    text-decoration: none;
  }

  .related-card:hover {
    transform: translateY(-4px);
    border-color: #38bdf8;
  }

  .related-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 14px;
  }

  .related-top span {
    color: #38bdf8;
    font-size: 12px;
    font-weight: bold;
  }

  .related-top strong {
    color: #86efac;
    font-size: 12px;
  }

  .related-card h3 {
    margin: 12px 0;
    color: #f9fafb;
  }

  .related-card p {
    color: #9ca3af;
    line-height: 1.7;
  }

  .side-button {
    margin-top: 18px;
    display: inline-flex;
    padding: 10px 16px;
    border-radius: 999px;
    background: #1e3a8a;
    color: #bfdbfe;
    font-weight: 800;
    font-size: 13px;
  }
</style>
