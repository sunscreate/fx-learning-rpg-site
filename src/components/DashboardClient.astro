<div id="learning-dashboard-root"></div>

<script>
  const STORAGE_KEY = "fx_quest_guild_save_data";

  const defaultSaveData = {
    totalExp: 0,
    currentLevel: 1,
    learnedArticles: [],
    completedQuests: [],
    dailyStreak: 0,
    lastLoginDate: null,
  };

  const expTable = [
    0, 100, 250, 450, 700,
    1000, 1400, 1900, 2500,
    3200, 4000, 5000, 6500,
    8500, 11000,
  ];

  function loadSaveData() {
    const saved = localStorage.getItem(STORAGE_KEY);

    if (!saved) {
      localStorage.setItem(
        STORAGE_KEY,
        JSON.stringify(defaultSaveData)
      );

      return defaultSaveData;
    }

    try {
      return {
        ...defaultSaveData,
        ...JSON.parse(saved),
      };
    } catch {
      return defaultSaveData;
    }
  }

  function getCurrentLevel(exp) {
    let level = 1;

    for (let i = 0; i < expTable.length; i++) {
      if (exp >= expTable[i]) {
        level = i + 1;
      }
    }

    return level;
  }

  function getTitle(level) {
    if (level >= 20) return "Guild Master";
    if (level >= 15) return "Market Knight";
    if (level >= 10) return "Elite Trader";
    if (level >= 5) return "Adventurer";
    return "Novice";
  }

  const data = loadSaveData();
  const level = getCurrentLevel(data.totalExp);
  const title = getTitle(level);
  const learnedCount = data.learnedArticles.length;

  const root = document.getElementById(
    "learning-dashboard-root"
  );

  root.innerHTML = `
    <section class="dashboard-card">
      <div class="dashboard-header">Guild Status</div>

      <div class="dashboard-grid">
        <div class="dashboard-item">
          <span>LEVEL</span>
          <strong>LV ${level}</strong>
        </div>

        <div class="dashboard-item">
          <span>TITLE</span>
          <strong>${title}</strong>
        </div>

        <div class="dashboard-item">
          <span>TOTAL EXP</span>
          <strong>${data.totalExp}</strong>
        </div>

        <div class="dashboard-item">
          <span>LEARNED</span>
          <strong>${learnedCount}</strong>
        </div>
      </div>

      <div class="next-quest">
        <span>NEXT QUEST</span>
        <strong>→ 次のQUESTへ進む</strong>
      </div>
    </section>
  `;
</script>

<style>
  .dashboard-card {
    background: #111827;
    border: 1px solid #1f2937;
    border-radius: 20px;
    padding: 32px;
    margin: 40px 0;
  }

  .dashboard-header {
    font-size: 28px;
    font-weight: bold;
    margin-bottom: 32px;
    color: #f9fafb;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns:
      repeat(auto-fit, minmax(180px, 1fr));
    gap: 18px;
    margin-bottom: 36px;
  }

  .dashboard-item {
    background: #0f172a;
    border-radius: 14px;
    padding: 20px;
    border: 1px solid #1f2937;
  }

  .dashboard-item span {
    display: block;
    margin-bottom: 10px;
    font-size: 12px;
    color: #9ca3af;
  }

  .dashboard-item strong {
    color: #f9fafb;
    font-size: 24px;
  }

  .next-quest {
    background: #0f172a;
    border: 1px solid #1f2937;
    border-radius: 16px;
    padding: 20px;
  }

  .next-quest span {
    display: block;
    margin-bottom: 12px;
    color: #9ca3af;
    font-size: 12px;
  }

  .next-quest strong {
    color: #00ff99;
    font-size: 22px;
  }
</style>
