<section class="streak-mission">

  <div class="mission-header">

    <p class="eyebrow">
      DAILY QUEST
    </p>

    <h2>
      AIデイリーミッション
    </h2>

  </div>

  <div
    id="mission-content"
    class="mission-content"
  ></div>

</section>

<script type="module">

import {
  getLearningData,
} from "../utils/learningEngine.js";

const data =
  getLearningData();

const viewed =
  data.viewed.length;

const completed =
  data.completed.length;

const weakTag =
  Object.entries(data.tags)
    .sort((a, b) => a[1] - b[1])[0];

const content =
  document.getElementById(
    "mission-content"
  );

let mission =
  "まずはQUESTを1つ閲覧しましょう。";

if (viewed >= 5) {

  mission =
    "今日は3QUEST以上読んで理解を深めましょう。";

}

if (completed >= 10) {

  mission =
    "苦手タグを重点攻略しましょう。";

}

if (weakTag) {

  mission += `
    現在の重点タグ：
    #${weakTag[0]}
  `;

}

content.innerHTML = `

  <div class="mission-box">

    <p>
      ${mission}
    </p>

  </div>

`;

</script>

<style>

.streak-mission {
  margin: 60px 0;
}

.mission-header {
  margin-bottom: 24px;
}

.mission-box {
  padding: 28px;

  border-radius: 24px;

  background:
    linear-gradient(
      135deg,
      #172554,
      #111827
    );

  border: 1px solid #2563eb;
}

.mission-box p {
  color: #dbeafe;
  line-height: 2;
  font-size: 18px;
}

</style>
