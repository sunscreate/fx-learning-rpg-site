<section class="ai-profile">

  <div class="profile-header">

    <p class="eyebrow">
      PLAYER ANALYSIS
    </p>

    <h2>
      AI学習プロフィール
    </h2>

  </div>

  <div
    id="profile-grid"
    class="profile-grid"
  ></div>

</section>

<script type="module">

import {
  getLearningData,
} from "/fx-learning-rpg-site/utils/learningEngine.js";

const data =
  getLearningData();

const completed =
  data.completed.length;

const viewed =
  data.viewed.length;

const favoriteTag =
  Object.entries(data.tags)
    .sort((a, b) => b[1] - a[1])[0];

const strongLevel =
  Object.entries(data.levels)
    .sort((a, b) => b[1] - a[1])[0];

const grid =
  document.getElementById(
    "profile-grid"
  );

grid.innerHTML = `

  <div class="profile-card">
    <h3>閲覧QUEST</h3>
    <p>${viewed}</p>
  </div>

  <div class="profile-card">
    <h3>完了QUEST</h3>
    <p>${completed}</p>
  </div>

  <div class="profile-card">
    <h3>得意タグ</h3>
    <p>
      ${
        favoriteTag
        ? "#" + favoriteTag[0]
        : "-"
      }
    </p>
  </div>

  <div class="profile-card">
    <h3>主力LEVEL</h3>
    <p>
      ${
        strongLevel
        ? "LEVEL " + strongLevel[0]
        : "-"
      }
    </p>
  </div>

`;

</script>

<style>

.ai-profile {
  margin: 60px 0;
}

.profile-header {
  margin-bottom: 24px;
}

.profile-grid {
  display: grid;

  grid-template-columns:
    repeat(
      auto-fit,
      minmax(220px, 1fr)
    );

  gap: 20px;
}

.profile-card {
  padding: 24px;

  border-radius: 20px;

  background: #111827;

  border: 1px solid #1f2937;
}

.profile-card h3 {
  color: #9ca3af;
  margin-bottom: 12px;
}

.profile-card p {
  color: white;
  font-size: 28px;
  font-weight: 700;
}

</style>
