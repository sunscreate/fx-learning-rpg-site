---
const TOTAL_QUESTS = 100;
---

<section class="completion-rate">

  <div class="completion-header">

    <p class="eyebrow">
      COMPLETION SYSTEM
    </p>

    <h2>
      AI学習進捗率
    </h2>

  </div>

  <div
    id="completion-content"
    class="completion-content"
  ></div>

</section>

<script define:vars={{ TOTAL_QUESTS }} type="module">

import {
  getLearningData,
} from "../utils/learningEngine.js";

const data =
  getLearningData();

const completed =
  data.completed.length;

const rate =
  Math.min(
    100,
    Math.round(
      (completed / TOTAL_QUESTS) * 100
    )
  );

const el =
  document.getElementById(
    "completion-content"
  );

el.innerHTML = `

  <div class="completion-box">

    <div class="completion-bar">

      <div
        class="completion-fill"
        style="width:${rate}%"
      ></div>

    </div>

    <div class="completion-info">

      <h3>
        ${rate}%
      </h3>

      <p>
        ${completed} / ${TOTAL_QUESTS}
        QUEST COMPLETE
      </p>

    </div>

  </div>

`;

</script>

<style>

.completion-rate {
  margin: 60px 0;
}

.completion-header {
  margin-bottom: 24px;
}

.completion-box {
  padding: 32px;

  border-radius: 24px;

  background: #111827;

  border: 1px solid #1f2937;
}

.completion-bar {
  width: 100%;
  height: 22px;

  border-radius: 999px;

  background: #1f2937;

  overflow: hidden;

  margin-bottom: 20px;
}

.completion-fill {
  height: 100%;

  border-radius: 999px;

  background:
    linear-gradient(
      90deg,
      #2563eb,
      #10b981
    );
}

.completion-info h3 {
  color: white;

  font-size: clamp(2rem, 6vw, 4rem);

  margin-bottom: 10px;
}

.completion-info p {
  color: #9ca3af;
}

</style>
