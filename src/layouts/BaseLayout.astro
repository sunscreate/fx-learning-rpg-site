---
import "../styles/global.css";
import Footer from "../components/Footer.astro";

const {
  title = "FX Quest Guild",
  description,
  image = "https://sunscreate.github.io/fx-learning-rpg-site/ogp.png",
  noindex = false,
} = Astro.props;

const fallbackDescription =
  `${title} を初心者向けにわかりやすく解説。` +
  "意味・使い方・注意点・実践での活用方法までRPG風に学べるFX Quest Guildの学習記事。" +
  "基礎知識からトレード判断へのつなげ方まで、クエスト形式で順番に理解できるよう整理しています。";

const pageDescription =
  description || fallbackDescription;

const robotsContent =
  typeof noindex === "string"
    ? noindex
    : noindex
    ? "noindex,nofollow"
    : "";

const siteBase = "https://sunscreate.github.io/fx-learning-rpg-site";

const canonicalUrl =
  `${siteBase}${Astro.url.pathname.replace(/^\/fx-learning-rpg-site/, "")}`;
  
const websiteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "FX Quest Guild",
  url: `${siteBase}/`,
  description: pageDescription,
  potentialAction: {
    "@type": "SearchAction",
    target: `${siteBase}/search/?q={search_term_string}`,
    "query-input": "required name=search_term_string",
  },
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <meta name="description" content={pageDescription} />

    {robotsContent && (
      <meta name="robots" content={robotsContent} />
    )}

    <title>{title}</title>

    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={image} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="FX Quest Guild" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={image} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(websiteJsonLd)}
    />
  </head>

  <body>
    <slot />

    <Footer />
  </body>
</html>
