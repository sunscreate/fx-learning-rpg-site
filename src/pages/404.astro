---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="404 | FX Quest Guild"
  description="ページが見つかりません"
  noindex="noindex,nofollow"
>

  <main class="notfound-page">

    <section class="notfound-box">

      <p class="error-code">
        ERROR 404
      </p>

      <h1>
        QUESTが見つかりません
      </h1>

      <p>
        指定されたQUESTは
        ギルドに存在しないようです。
      </p>

      <div class="notfound-links">

        <a href="/fx-learning-rpg-site/">
          ホームへ戻る
        </a>

        <a href="/fx-learning-rpg-site/search/">
          QUEST検索
        </a>

        <a href="/fx-learning-rpg-site/tag/">
          タグ探索
        </a>

      </div>

    </section>

  </main>

</BaseLayout>

<style>

.notfound-page {
  min-height: 70vh;

  display: flex;
  align-items: center;
  justify-content: center;

  width: min(900px, 92%);
  margin: 0 auto;
}

.notfound-box {
  width: 100%;

  padding: 60px;

  border-radius: 30px;

  background: #111827;

  border: 1px solid #1f2937;

  text-align: center;
}

.error-code {
  color: #60a5fa;
  font-weight: 700;
  margin-bottom: 12px;
}

.notfound-box h1 {
  color: white;
  font-size: clamp(2rem, 6vw, 4rem);
  margin-bottom: 18px;
}

.notfound-box p {
  color: #9ca3af;
}

.notfound-links {
  margin-top: 30px;

  display: flex;
  justify-content: center;
  gap: 14px;
  flex-wrap: wrap;
}

.notfound-links a {
  padding: 12px 18px;

  border-radius: 999px;

  background: #2563eb;

  color: white;

  text-decoration: none;
}

.notfound-links a:hover {
  background: #3b82f6;
}

</style>
